{
    "name": "Grid-Environmental-Services",
    "version": "0.0.2",
    "description": "Remote sensing and climate data services provided from a geographic grids.",
    "engines": {
        "arangodb": "^3.0.0"
    },
    "author": "Milko Škofič",
    "license": "Apache 2",
    "main": "main.js",
    "scripts": {
        "setup": "scripts/setup.js",
        "teardown": "scripts/teardown.js"
    },
    "configuration": {
        "collectionChelsa": {
            "description": "Chelsa collection name",
            "type": "string",
            "required": true,
            "default": "Chelsa"
        },
        "collectionWorldClim": {
            "description": "WorldClim collection name",
            "type": "string",
            "required": true,
            "default": "WorldClim"
        },
        "collectionDroughtObservatory": {
            "description": "DroughtObservatory collection name",
            "type": "string",
            "required": true,
            "default": "DroughtObservatory"
        },
        "collectionDroughtObservatoryMap": {
            "description": "DroughtObservatoryMap collection name",
            "type": "string",
            "required": true,
            "default": "DroughtObservatoryMap"
        },
        "collectionDataset": {
            "description": "Dataset collection name",
            "type": "string",
            "required": true,
            "default": "Dataset"
        },
        "viewDataset": {
            "description": "Dataset view name",
            "type": "string",
            "required": true,
            "default": "VIEW_DATASET"
        }
    },
    "tests": "test/**/*.js"
}
